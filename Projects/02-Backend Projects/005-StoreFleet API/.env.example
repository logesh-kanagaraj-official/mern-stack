# Copy this file and rename it to envVariables.env, then fill in your actual values.
# Never commit the real envVariables.env file!

PORT=3000
DBURL=mongodb://0.0.0.0:27017

# Generate a strong random secret: https://randomkeygen.com/
JWT_Secret=your_jwt_secret_here
JWT_Expire=1d
COOKIE_EXPIRES_IN=1

# Use a Gmail account with App Password enabled (not your regular password)
# Enable App Passwords: https://myaccount.google.com/apppasswords
STORFLEET_SMPT_MAIL=your_email@gmail.com
STORFLEET_SMPT_MAIL_PASSWORD=your_gmail_app_password_here
SMPT_SERVICE=gmail
